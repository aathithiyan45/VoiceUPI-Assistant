<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.VoiceUPI" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.VoiceUPI.GPay" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/gpay_bg</item>
        <item name="android:statusBarColor">@color/gpay_bg</item>
        <item name="android:navigationBarColor">@color/gpay_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

</resources>