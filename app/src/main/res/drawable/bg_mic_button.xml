<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Listening state (isSelected = true) — glowing orange -->
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#FF5722"/>
            <size android:width="160dp" android:height="160dp"/>
        </shape>
    </item>

    <!-- Pressed feedback -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#FF7043"/>
            <size android:width="160dp" android:height="160dp"/>
        </shape>
    </item>

    <!-- Idle default — dark navy with subtle border -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1A2235"/>
            <stroke android:width="2dp" android:color="#263550"/>
            <size android:width="160dp" android:height="160dp"/>
        </shape>
    </item>

</selector>