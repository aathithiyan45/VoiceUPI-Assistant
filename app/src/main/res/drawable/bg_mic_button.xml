<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_mic_button.xml
    Circle background for the mic ImageButton.
    Default (idle)    → dark grey  #2C2C2C
    Selected (listening) → orange  #E65100
    Pressed           → slightly lighter orange
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Listening state (isSelected = true, set by code) -->
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#E65100"/>
            <size android:width="160dp" android:height="160dp"/>
        </shape>
    </item>

    <!-- Pressed feedback -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#FF7043"/>
            <size android:width="160dp" android:height="160dp"/>
        </shape>
    </item>

    <!-- Idle default -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#2C2C2C"/>
            <size android:width="160dp" android:height="160dp"/>
        </shape>
    </item>

</selector>