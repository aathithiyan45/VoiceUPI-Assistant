<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_confirmation.xml
    Displays merchant name, amount, and UPI ID in large accessible text.
    Voice is the primary interaction channel; buttons are intentionally omitted.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:importantForAccessibility="yes">

    <!-- ── Screen label ───────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvScreenLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirm Payment"
        android:textColor="#BDBDBD"
        android:textSize="18sp"
        android:fontFamily="sans-serif"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- ── Paying label ───────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvPayingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paying"
        android:textColor="#757575"
        android:textSize="20sp"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toBottomOf="@id/tvScreenLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- ── Amount — largest, most prominent ───────────────────────────── -->
    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹0"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        android:fontFamily="sans-serif-medium"
        android:contentDescription="Amount"
        android:accessibilityLiveRegion="polite"
        app:layout_constraintTop_toBottomOf="@id/tvPayingLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- ── "to" label ─────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvToLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="to"
        android:textColor="#757575"
        android:textSize="20sp"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toBottomOf="@id/tvAmount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- ── Merchant name ──────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvMerchant"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Merchant"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingHorizontal="32dp"
        android:contentDescription="Merchant name"
        app:layout_constraintTop_toBottomOf="@id/tvToLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- ── UPI ID (secondary detail, smaller) ─────────────────────────── -->
    <TextView
        android:id="@+id/tvUpiId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="upi@bank"
        android:textColor="#9E9E9E"
        android:textSize="18sp"
        android:gravity="center"
        android:paddingHorizontal="48dp"
        android:contentDescription="UPI ID"
        app:layout_constraintTop_toBottomOf="@id/tvMerchant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- ── Divider ─────────────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#2C2C2C"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toBottomOf="@id/tvUpiId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="32dp" />

    <!-- ── Voice status ────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Awaiting confirmation…"
        android:textColor="#BDBDBD"
        android:textSize="22sp"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:lineSpacingMultiplier="1.3"
        android:accessibilityLiveRegion="polite"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp" />

</androidx.constraintlayout.widget.ConstraintLayout>