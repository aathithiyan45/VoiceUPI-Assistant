<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_success.xml
    Minimal, high-contrast success screen.
    Large tick + payment summary + auto-return countdown.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D2E0D"
    android:importantForAccessibility="yes">

    <!-- ── Success icon (large checkmark emoji via text) ──────────────── -->
    <TextView
        android:id="@+id/tvCheckmark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓"
        android:textColor="#4CAF50"
        android:textSize="96sp"
        android:fontFamily="sans-serif-medium"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSuccessTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

    <!-- ── Success heading ────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvSuccessTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Successful!"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:contentDescription="Payment Successful"
        android:accessibilityLiveRegion="polite"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvPaymentDetails"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Payment detail (amount + merchant) ─────────────────────────── -->
    <TextView
        android:id="@+id/tvPaymentDetails"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="₹0 paid to Merchant"
        android:textColor="#A5D6A7"
        android:textSize="22sp"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:contentDescription="Payment details"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessTitle"
        app:layout_constraintBottom_toTopOf="@id/tvCountdown"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- ── Auto-return countdown ─────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Returning in 3…"
        android:textColor="#757575"
        android:textSize="16sp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="64dp" />

</androidx.constraintlayout.widget.ConstraintLayout>