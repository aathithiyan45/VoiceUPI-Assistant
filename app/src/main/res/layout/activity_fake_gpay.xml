<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gpay_bg">

    <!-- ── TOP BAR ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/gpay_bg"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="G" android:textColor="#4285F4" android:textSize="23sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="o" android:textColor="#EA4335" android:textSize="23sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="o" android:textColor="#FBBC04" android:textSize="23sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="g" android:textColor="#4285F4" android:textSize="23sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="le" android:textColor="#34A853" android:textSize="23sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" Pay" android:textColor="#202124" android:textSize="23sp" android:textStyle="bold"/>

        <!-- Spacer -->
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- ── Thin divider ──────────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gpay_light_grey"
        app:layout_constraintTop_toBottomOf="@id/topBar"/>

    <!-- ── Scroll content ────────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="32dp">

            <!-- Merchant avatar circle -->
            <TextView
                android:id="@+id/tvMerchantAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="36dp"
                android:background="@drawable/circle_green_bg"
                android:gravity="center"
                android:text="G"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <!-- Merchant name -->
            <TextView
                android:id="@+id/tvGPayMerchant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Merchant"
                android:textColor="@color/gpay_dark"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <!-- UPI ID -->
            <TextView
                android:id="@+id/tvGPayUpiId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="merchant@upi"
                android:textColor="@color/gpay_grey"
                android:textSize="13sp"/>

            <!-- Thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="24dp"
                android:background="@color/gpay_light_grey"/>

            <!-- Amount -->
            <TextView
                android:id="@+id/tvGPayAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="₹0"
                android:textColor="@color/gpay_dark"
                android:textSize="52sp"
                android:fontFamily="sans-serif-medium"/>

            <!-- Pay from card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPayFrom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/circle_green_bg"
                        android:gravity="center"
                        android:text="🏦"
                        android:textSize="18sp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paying from"
                            android:textColor="@color/gpay_grey"
                            android:textSize="11sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="•••• 4242  |  SBI Bank"
                            android:textColor="@color/gpay_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/gpay_grey"
                        android:textSize="22sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fingerprint icon -->
            <ImageView
                android:id="@+id/ivFingerprint"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="36dp"
                android:src="@drawable/ic_fingerprint"
                android:tint="@color/gpay_blue"
                android:contentDescription="Fingerprint sensor"/>

            <!-- Biometric hint -->
            <TextView
                android:id="@+id/tvBiometricHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Touch sensor to pay"
                android:textColor="@color/gpay_grey"
                android:textSize="14sp"/>

            <!-- Secured by -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="🔒  Secured by Google Pay"
                android:textColor="#9AA0A6"
                android:textSize="12sp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>