<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_language_selection.xml
    High-contrast, accessible language picker.
    Two full-width buttons fill most of the screen so visually impaired
    users can find them easily by touch exploration (TalkBack).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:gravity="center"
    android:padding="24dp">

    <!-- App title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice UPI"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:importantForAccessibility="no"
        android:layout_marginBottom="8dp"/>

    <!-- Sub-prompt in both languages -->
    <TextView
        android:id="@+id/tvPrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="மொழியை தேர்வு செய்யவும் / Choose your language"
        android:textColor="#BDBDBD"
        android:textSize="17sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="56dp"
        android:importantForAccessibility="no"/>

    <!-- Tamil button — saffron/orange -->
    <Button
        android:id="@+id/btnTamil"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="🇮🇳  தமிழ்"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#E65100"
        android:layout_marginBottom="20dp"
        android:contentDescription="தமிழ் மொழி தேர்வு. Tamil language."
        android:importantForAccessibility="yes"
        android:focusable="true"
        android:clickable="true"
        style="?android:attr/buttonStyle" />

    <!-- English button — blue -->
    <Button
        android:id="@+id/btnEnglish"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="🇬🇧  English"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#1565C0"
        android:contentDescription="English language. ஆங்கில மொழி தேர்வு."
        android:importantForAccessibility="yes"
        android:focusable="true"
        android:clickable="true"
        style="?android:attr/buttonStyle" />

</LinearLayout>