<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Subtle top gradient band ────────────────────────────────────── -->
    <View
        android:id="@+id/topGlow"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:alpha="0.35"
        android:background="#1AFF5722"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- ── App logo / icon area ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:text="🎙"
        android:textSize="36sp"
        android:gravity="center"
        android:background="@drawable/bg_mic_button"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp"/>

    <!-- ── App name ─────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice UPI"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.06"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toBottomOf="@id/tvIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- ── Sub-prompt ───────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvPrompt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="மொழியை தேர்வு செய்யவும்\nChoose your language"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="32dp"/>

    <!-- ── Buttons container ────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/btnContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvPrompt"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <!-- Tamil button -->
        <Button
            android:id="@+id/btnTamil"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="🇮🇳  தமிழ்"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_lang_tamil"
            android:elevation="6dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp"
            android:contentDescription="தமிழ் மொழி தேர்வு. Tamil language."
            android:importantForAccessibility="yes"
            android:focusable="true"
            android:clickable="true"/>

        <!-- English button -->
        <Button
            android:id="@+id/btnEnglish"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="🇬🇧  English"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_lang_english"
            android:elevation="6dp"
            android:stateListAnimator="@null"
            android:contentDescription="English language. ஆங்கில மொழி தேர்வு."
            android:importantForAccessibility="yes"
            android:focusable="true"
            android:clickable="true"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>